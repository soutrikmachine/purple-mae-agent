# Copy to .env and fill in your values.

# --- A2A server ---
HOST=0.0.0.0
PORT=9009                                    # matches Amber manifest
# AGENT_URL=https://my-purple.example.com/   # advertised on agent card

AGENT_NAME=Purple MAE Negotiator
LOG_LEVEL=INFO
UVICORN_LOG_LEVEL=info

# --- Strategy knob ---
OPENING_AGGRESSIVENESS=0.75                  # 0.60 welfare-first, 0.90 BATNA-first

# --- LLM refinement (optional) ----------------------------------------------
# Pure-strategy mode (default): zero LLM calls, zero cost.
USE_LLM=false

# Provider: "openrouter" (recommended) or "anthropic"
LLM_PROVIDER=openrouter

# Model examples and full-benchmark cost estimates:
#   openrouter -> "anthropic/claude-opus-4.7"    (~$0.30 full run)
#   openrouter -> "openai/gpt-4o-mini"         (~$0.40)
#   openrouter -> "deepseek/deepseek-chat"     (~$0.80)
#   openrouter -> "anthropic/claude-haiku-4.5" (~$3.50)
#   openrouter -> "anthropic/claude-sonnet-4"  (~$8)
#   openrouter -> "anthropic/claude-opus-4.7"  (~$13)
LLM_MODEL=anthropic/claude-opus-4.7

# Per-call LLM timeout. On expiry we fall back to the deterministic strategy.
LLM_TIMEOUT_S=45
LLM_MAX_TOKENS=2048

# Provider key (only one needed, matching LLM_PROVIDER):
# OPENROUTER_API_KEY=sk-or-v1-...
# ANTHROPIC_API_KEY=sk-ant-...

# Optional OpenRouter analytics
# OPENROUTER_REFERER=https://agentbeats.dev
# OPENROUTER_APP_TITLE=Purple MAE Agent

# --- RL refinement (optional, advanced) -------------------------------------
# Stub by default. To enable:
#   1. Pull an NFSP or RNAD checkpoint from the green's rl_agent_checkpoints/
#   2. Copy it into the image (or mount at runtime)
#   3. Set USE_RL=true and the path below
#   4. Add open_spiel + torch to requirements.txt
#   5. Implement _propose_from_checkpoint() in rl_proposer.py (see TODOs)
USE_RL=false
RL_ALGO=nfsp                                 # or "rnad"
# RL_CHECKPOINT_PATH=/app/rl_checkpoints/nfsp_bg5.pt
